<%
  const formErrors = Array.isArray(errors) ? errors : [];
  const errorsByField = formErrors.reduce((acc, error) => {
    const field = error.path || error.param || 'form';
    acc[field] = acc[field] || [];
    acc[field].push(error.msg || error);
    return acc;
  }, {});
  const formValue = (field, fallback = '') => {
    if (oldInput && Object.prototype.hasOwnProperty.call(oldInput, field)) {
      return oldInput[field] || '';
    }
    return fallback || '';
  };
  const inputClass = (field) => errorsByField[field] ? ' is-invalid' : '';
%>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Редактирование профиля</h4>
        </div>
        <div class="card-body p-4">
          <% if (formErrors.length) { %>
            <div class="alert alert-danger" role="alert">
              <h6 class="alert-heading mb-2"><i class="bi bi-exclamation-circle"></i> Проверьте данные профиля</h6>
              <ul class="mb-0 ps-3">
                <% formErrors.forEach(error => { %>
                  <li><%= error.msg || error %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>

          <div class="text-center mb-4">
            <% if (user.avatar && user.avatar !== 'default-avatar.png') { %>
              <img src="/uploads/avatars/<%= user.avatar %>"
                   class="rounded-circle mb-3"
                   width="100" height="100"
                   alt="Аватар">
            <% } else { %>
              <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-3"
                   style="width: 100px; height: 100px;">
                <span class="text-white display-6">
                  <%= user.username.charAt(0).toUpperCase() %>
                </span>
              </div>
            <% } %>

            <form action="/profile/avatar?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="mb-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label for="avatar" class="form-label">Сменить аватар</label>
              <div class="input-group">
                <input type="file" class="form-control" id="avatar" name="avatar" accept="image/jpeg,image/jpg,image/png,image/gif" required>
                <button type="submit" class="btn btn-outline-primary">Загрузить</button>
              </div>
              <div class="form-text">Максимальный размер: 5MB. Разрешены: JPG, PNG, GIF</div>
            </form>
          </div>

          <form action="/profile" method="POST" id="profileEditForm" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="_method" value="PUT">
            
            <div class="mb-3">
              <label for="username" class="form-label">Имя пользователя *</label>
              <input type="text" class="form-control<%= inputClass('username') %>" id="username" name="username"
                     value="<%= formValue('username', user.username) %>" minlength="3" maxlength="50"
                     pattern="[A-Za-z0-9_]+" data-original-value="<%= user.username %>" required>
              <% if (errorsByField.username) { %>
                <div class="invalid-feedback"><%= errorsByField.username[0] %></div>
              <% } %>
              <div class="form-text">От 3 до 50 символов: латинские буквы, цифры и подчеркивания.</div>
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email адрес *</label>
              <input type="email" class="form-control<%= inputClass('email') %>" id="email" name="email"
                     value="<%= formValue('email', user.email) %>" maxlength="100"
                     data-original-value="<%= user.email %>" required>
              <% if (errorsByField.email) { %>
                <div class="invalid-feedback"><%= errorsByField.email[0] %></div>
              <% } %>
            </div>
            
            <div class="card border-warning mb-4">
              <div class="card-header bg-warning">
                <h6 class="mb-0">Смена пароля</h6>
              </div>
              <div class="card-body">
                <p class="text-muted small mb-3">
                  Оставьте поля нового пароля пустыми, если не хотите менять пароль.
                  Текущий пароль потребуется для смены имени, email или пароля.
                </p>

                <div class="mb-3">
                  <label for="currentPassword" class="form-label">Текущий пароль</label>
                  <input type="password" class="form-control<%= inputClass('currentPassword') %>" id="currentPassword" name="currentPassword"
                         autocomplete="current-password">
                  <% if (errorsByField.currentPassword) { %>
                    <div class="invalid-feedback"><%= errorsByField.currentPassword[0] %></div>
                  <% } %>
                  <div class="form-text">Обязателен при изменении имени, email или пароля.</div>
                </div>

                <div class="mb-3">
                  <label for="newPassword" class="form-label">Новый пароль</label>
                  <input type="password" class="form-control<%= inputClass('newPassword') %>" id="newPassword" name="newPassword"
                         minlength="6" maxlength="255" pattern="(?=.*\d).{6,}" autocomplete="new-password">
                  <% if (errorsByField.newPassword) { %>
                    <div class="invalid-feedback"><%= errorsByField.newPassword[0] %></div>
                  <% } %>
                  <div class="form-text">От 6 символов, должна быть хотя бы одна цифра.</div>
                </div>

                <div class="mb-3">
                  <label for="confirmPassword" class="form-label">Подтверждение нового пароля</label>
                  <input type="password" class="form-control<%= inputClass('confirmPassword') %>" id="confirmPassword" name="confirmPassword"
                         autocomplete="new-password">
                  <% if (errorsByField.confirmPassword) { %>
                    <div class="invalid-feedback"><%= errorsByField.confirmPassword[0] %></div>
                  <% } %>
                </div>
              </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
              <a href="/profile" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Назад к профилю
              </a>
              <div>
                <button type="submit" class="btn btn-primary px-4">
                  <i class="bi bi-check-lg"></i> Сохранить изменения
                </button>
              </div>
            </div>
          </form>


          <div class="card border-danger mt-4">
            <div class="card-header bg-danger text-white">
              <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Опасная зона</h6>
            </div>
            <div class="card-body">
              <p class="card-text">
                Удаление аккаунта приведет к полной потере всех данных: привычек,
                достижений, статистики. Это действие нельзя отменить.
              </p>
              <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                <i class="bi bi-trash"></i> Удалить аккаунт
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


<div class="modal fade" id="deleteAccountModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Удаление аккаунта</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Вы уверены, что хотите удалить свой аккаунт?</p>
        <p class="text-danger"><strong>Это действие нельзя отменить!</strong></p>
        <p>Все ваши данные будут безвозвратно удалены.</p>

        <form action="/profile/delete" method="POST" id="deleteAccountForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label for="confirmPasswordDelete" class="form-label">
              Для подтверждения введите свой пароль:
            </label>
            <input type="password" class="form-control" id="confirmPasswordDelete"
                   name="password" autocomplete="current-password" required>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
        <button type="submit" form="deleteAccountForm" class="btn btn-danger">
          Удалить аккаунт
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('profileEditForm');
    if (!form) return;

    const username = document.getElementById('username');
    const email = document.getElementById('email');
    const currentPassword = document.getElementById('currentPassword');
    const newPassword = document.getElementById('newPassword');
    const confirmPassword = document.getElementById('confirmPassword');

    const profileChanged = () => (
      username.value !== username.dataset.originalValue ||
      email.value !== email.dataset.originalValue
    );

    const passwordChangeRequested = () => Boolean(newPassword.value || confirmPassword.value);

    const validatePasswords = () => {
      currentPassword.required = profileChanged() || passwordChangeRequested();

      if (passwordChangeRequested() && newPassword.value !== confirmPassword.value) {
        confirmPassword.setCustomValidity('Подтверждение нового пароля не совпадает');
      } else {
        confirmPassword.setCustomValidity('');
      }
    };

    [username, email, currentPassword, newPassword, confirmPassword].forEach((field) => {
      field.addEventListener('input', validatePasswords);
      field.addEventListener('change', validatePasswords);
    });

    form.addEventListener('submit', (event) => {
      validatePasswords();
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    });

    validatePasswords();
  });
</script>
