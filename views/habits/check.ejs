<%
  const habitColor = habit.color || '#28a745';
  const currentValue = habit.getDataValue ? (habit.getDataValue('periodValue') || 0) : (habit.periodValue || 0);
  const progressValue = habit.getDataValue ? (habit.getDataValue('progressPercentage') || 0) : Math.min((currentValue / habit.targetValue) * 100, 100);
  const currentStreak = habit.currentStreak || 0;
  const frequencyLabel = habit.frequency === 'daily' ? 'Ежедневно' : habit.frequency === 'weekly' ? 'Еженедельно' : 'Ежемесячно';
  const categoryLabel = habit.category === 'water' ? '💧 Вода' :
    habit.category === 'energy' ? '⚡ Энергия' :
    habit.category === 'waste' ? '🗑️ Отходы' :
    habit.category === 'transport' ? '🚗 Транспорт' :
    habit.category === 'food' ? '🍎 Питание' : '🌱 Прочее';
  const unitLabels = {
    times: 'раз',
    liters: 'литров',
    kwh: 'кВт·ч',
    kg: 'кг',
    items: 'шт.'
  };
  const displayUnit = unitLabels[habit.unit] || habit.unit;
  const actionVerb = habit.category === 'water' ? 'сэкономили' :
    habit.category === 'energy' ? 'сберегли' :
    habit.category === 'waste' ? 'переработали' :
    habit.category === 'transport' ? 'проехали экологично' :
    habit.category === 'food' ? 'выбрали экологично' : 'сделали';
%>

<div class="container py-4 checkin-page">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
      <div class="checkin-card card shadow border-0 overflow-hidden">
        <div class="checkin-hero text-white" style="--habit-color: <%= habitColor %>; background: linear-gradient(135deg, <%= habitColor %> 0%, #198754 100%); color: #fff;">
          <div class="checkin-hero__content d-flex align-items-center gap-3">
            <div class="checkin-hero__icon">
            </div>
            <div class="min-width-0">
              <p class="checkin-hero__eyebrow mt-2 mb-0">Отметка выполнения</p>
              <h1 class="checkin-hero__title mb-4"><%= habit.title %></h1>
            </div>
          </div>
        </div>

        <div class="card-body p-4 p-md-5">
          <section class="progress-panel mb-4">
            <div class="d-flex flex-wrap justify-content-between gap-2 mb-3">
              <div>
                <h2 class="h5 mb-1">Текущий прогресс</h2>
                <p class="text-muted mb-0">Выполнено <strong><%= currentValue %> <%= displayUnit %></strong> из <strong><%= habit.targetValue %> <%= displayUnit %></strong></p>
              </div>
              <div class="progress-panel__percent" style="color: <%= habitColor %>;">
                <%= progressValue.toFixed(1) %>%
              </div>
            </div>
            <div class="progress checkin-progress">
              <div
                class="progress-bar"
                role="progressbar"
                style="width: <%= progressValue %>%; background-color: <%= habitColor %>;"
                aria-valuenow="<%= progressValue.toFixed(0) %>"
                aria-valuemin="0"
                aria-valuemax="100"
              ></div>
            </div>
            <div class="streak-strip mt-3">
              <div>
                <i class="bi bi-fire text-warning"></i>
                <span class="fw-semibold">Текущая серия:</span> <%= currentStreak %> дней
              </div>
              <% if (habit.bestStreak > currentStreak) { %>
                <div>
                  <i class="bi bi-trophy text-warning"></i>
                  <span class="fw-semibold">Рекорд:</span> <%= habit.bestStreak %> дней
                </div>
              <% } %>
            </div>
          </section>

          <form action="/habits/<%= habit.id %>/check" method="POST" class="checkin-form">
            <div class="mb-4">
              <label for="value" class="form-label fw-semibold">
                Сколько <%= displayUnit %> вы <%= actionVerb %> сегодня? <span class="text-danger">*</span>
              </label>
              <div class="input-group input-group-lg checkin-input">
                <input type="number" class="form-control" id="value" name="value" min="1" max="1000" value="1" required>
                <span class="input-group-text"><%= displayUnit %></span>
              </div>
              <div class="form-text">Минимум: 1 <%= displayUnit %>, максимум: 1000 <%= displayUnit %></div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold">Быстрый выбор</label>
              <div class="quick-values d-flex flex-wrap gap-2">
                <% const quickValues = [1, 5, 10, 25, 50]; %>
                <% quickValues.forEach((val, index) => { %>
                  <button
                    type="button"
                    class="btn quick-value <%= index === 0 ? 'active' : '' %>"
                    style="--habit-color: <%= habitColor %>;"
                    data-value="<%= val %>"
                  >
                    <%= val %> <%= displayUnit %>
                  </button>
                <% }); %>
              </div>
            </div>

            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label for="date" class="form-label fw-semibold">Дата выполнения</label>
                <input
                  type="date"
                  class="form-control form-control-lg"
                  id="date"
                  name="date"
                  value="<%= new Date().toISOString().split('T')[0] %>"
                  max="<%= new Date().toISOString().split('T')[0] %>"
                >
                <div class="form-text">Можно отметить выполнение за прошедшие дни</div>
              </div>
              <div class="col-md-6">
                <label for="notes" class="form-label fw-semibold">Примечание</label>
                <textarea
                  class="form-control"
                  id="notes"
                  name="notes"
                  rows="3"
                  placeholder="Что получилось хорошо?"
                ></textarea>
              </div>
            </div>

            <div class="checkin-actions d-flex flex-column flex-sm-row gap-3">
              <a href="/habits/<%= habit.id %>" class="btn btn-outline-secondary btn-lg flex-sm-fill">
                <i class="bi bi-arrow-left"></i> Назад
              </a>
              <button type="submit" class="btn btn-success btn-lg flex-sm-fill" style="background-color: <%= habitColor %>; border-color: <%= habitColor %>;">
                <i class="bi bi-check-lg"></i> Подтвердить
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.quick-value').forEach((button) => {
  button.addEventListener('click', function () {
    document.querySelectorAll('.quick-value').forEach((item) => item.classList.remove('active'));
    this.classList.add('active');
    document.getElementById('value').value = this.dataset.value;
  });
});

const checkinValueInput = document.getElementById('value');
if (checkinValueInput) {
  checkinValueInput.addEventListener('change', function () {
    const max = parseInt(this.max, 10);
    const value = parseInt(this.value, 10);

    if (value > max) {
      this.value = max;
      alert(`Максимальное значение: ${max} ${document.querySelector('.input-group-text').textContent}`);
    }
  });
}
</script>

<style>
.checkin-card,
.impact-card {
  border-radius: 1rem;
}

.checkin-hero {
  --habit-color: #28a745;
  padding: 1.75rem;
}

.checkin-hero__content {
  max-width: 100%;
}

.min-width-0 {
  min-width: 0;
}

.checkin-hero__icon,
.impact-card__icon {
  align-items: center;
  border-radius: 1rem;
  display: inline-flex;
  flex: 0 0 auto;
  height: 3rem;
  justify-content: center;
  width: 3rem;
}

.checkin-hero__icon {
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.14);
  color: #fff;
  font-size: 1.55rem;
}

.checkin-hero__eyebrow {
  color: rgba(255, 255, 255, 0.78);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.checkin-hero__title {
  color: #fff;
  font-size: clamp(1.55rem, 3vw, 2rem);
  font-weight: 800;
  line-height: 1.1;
  overflow-wrap: anywhere;
  text-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.16);
}

.checkin-hero__badges .badge {
  background: rgba(255, 255, 255, 0.94);
  color: #1f2937;
  font-size: 0.8rem;
  padding: 0.45rem 0.7rem;
}

.progress-panel {
  background: #f8fafc;
  border: 1px solid #e9ecef;
  border-radius: 1rem;
  padding: 1.25rem;
}

.progress-panel__percent {
  font-size: 1.6rem;
  font-weight: 800;
}

.checkin-progress {
  background-color: #e9ecef;
  border-radius: 999px;
  height: 0.9rem;
}

.checkin-progress .progress-bar {
  border-radius: 999px;
}

.streak-strip {
  background: #fff;
  border-radius: 0.75rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem 1.5rem;
  padding: 0.85rem 1rem;
}

.checkin-input .form-control,
.checkin-input .input-group-text,
.checkin-form .form-control,
.checkin-form .form-select {
  border-color: #d7dee8;
}

.quick-value {
  --habit-color: #28a745;
  background: #fff;
  border: 1px solid var(--habit-color);
  color: var(--habit-color);
  font-weight: 600;
  transition: all 0.2s ease;
}

.quick-value:hover,
.quick-value.active {
  background: var(--habit-color);
  color: #fff;
  transform: translateY(-1px);
}

.checkin-actions .btn {
  border-radius: 0.75rem;
}

@media (max-width: 575.98px) {
  .checkin-hero,
  .card-body.p-4.p-md-5 {
    padding: 1.25rem !important;
  }
}
</style>
