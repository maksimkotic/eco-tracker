<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1><i class="bi bi-stars text-success"></i> ИИ-помощник привычек</h1>
      <p class="text-muted mb-0">Опишите цель, а система предложит экологичные привычки для добавления в трекер.</p>
    </div>
    <a href="/habits" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> К привычкам
    </a>
  </div>

  <div class="row g-4">
    <div class="col-lg-5">
      <div class="card shadow h-100">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0"><i class="bi bi-magic"></i> Запрос к ИИ</h5>
        </div>
        <div class="card-body">
          <form action="/habits/ai" method="POST">
            <div class="mb-3">
              <label for="category" class="form-label">Категория</label>
              <select class="form-select" id="category" name="category" required>
                <% Object.entries(categories).forEach(([value, label]) => { %>
                  <option value="<%= value %>" <%= selectedCategory === value ? 'selected' : '' %>><%= label %></option>
                <% }); %>
              </select>
            </div>

            <div class="mb-3">
              <label for="goal" class="form-label">Цель или проблема</label>
              <textarea class="form-control" id="goal" name="goal" rows="5" maxlength="500"
                placeholder="Например: хочу меньше тратить электричество дома или начать сортировать отходы"><%= goal || '' %></textarea>
              <div class="form-text">Можно оставить пустым — тогда будут предложены универсальные привычки.</div>
            </div>

            <% if (habits && habits.length > 0) { %>
              <div class="alert alert-light border">
                <strong>Уже есть привычки:</strong>
                <ul class="mb-0 mt-2">
                  <% habits.slice(0, 5).forEach(habit => { %>
                    <li><%= habit.title %></li>
                  <% }); %>
                </ul>
              </div>
            <% } %>

            <button type="submit" class="btn btn-success w-100">
              <i class="bi bi-stars"></i> Сгенерировать рекомендации
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <% if (result) { %>
        <div class="alert <%= result.provider === 'openai' ? 'alert-success' : 'alert-warning' %>">
          <i class="bi bi-info-circle"></i>
          <%= result.note %>
          <div class="small mt-1">Провайдер: <strong><%= result.provider %></strong>, модель: <strong><%= result.model %></strong></div>
        </div>

        <div class="row g-3">
          <% result.suggestions.forEach((suggestion, index) => { %>
            <div class="col-md-6">
              <div class="card shadow h-100">
                <div class="card-body d-flex flex-column">
                  <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-success me-2">#<%= index + 1 %></span>
                    <h5 class="card-title mb-0"><%= suggestion.title %></h5>
                  </div>
                  <p class="card-text text-muted flex-grow-1"><%= suggestion.description %></p>
                  <div class="mb-3">
                    <span class="badge bg-secondary"><%= suggestion.frequency %></span>
                    <span class="badge bg-info text-dark"><%= suggestion.targetValue %> <%= suggestion.unit %></span>
                  </div>
                  <a class="btn btn-outline-success"
                    href="/habits/new?title=<%= encodeURIComponent(suggestion.title) %>&category=<%= encodeURIComponent(selectedCategory) %>">
                    <i class="bi bi-plus-circle"></i> Создать вручную
                  </a>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="card shadow h-100">
          <div class="card-body d-flex flex-column justify-content-center align-items-center text-center py-5">
            <i class="bi bi-robot text-success" style="font-size: 4rem;"></i>
            <h4 class="mt-3">Здесь появятся рекомендации</h4>
            <p class="text-muted mb-0">Выберите категорию и нажмите кнопку генерации.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
