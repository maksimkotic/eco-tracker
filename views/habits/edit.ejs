<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow">
        <div class="card-header bg-warning text-dark">
          <h4 class="mb-0">
            <i class="bi bi-pencil-square"></i> Редактирование привычки
          </h4>
        </div>
        <div class="card-body p-4">
          <form action="/habits/<%= habit.id %>" method="POST" id="editHabitForm">
            <input type="hidden" name="_method" value="PUT">


            <div class="mb-3">
              <label for="title" class="form-label">Название привычки *</label>
              <input type="text" class="form-control" id="title" name="title"
                     value="<%= habit.title %>" required>
              <div class="form-text">Короткое и понятное название</div>
            </div>


            <div class="mb-3">
              <label for="category" class="form-label">Категория *</label>
              <select class="form-select" id="category" name="category" required>
                <option value="">Выберите категорию</option>
                <option value="water" <%= habit.category === 'water' ? 'selected' : '' %>>💧 Экономия воды</option>
                <option value="energy" <%= habit.category === 'energy' ? 'selected' : '' %>>⚡ Экономия энергии</option>
                <option value="waste" <%= habit.category === 'waste' ? 'selected' : '' %>>🗑️ Сортировка отходов</option>
                <option value="transport" <%= habit.category === 'transport' ? 'selected' : '' %>>🚗 Экотранспорт</option>
                <option value="food" <%= habit.category === 'food' ? 'selected' : '' %>>🍎 Экопитание</option>
                <option value="other" <%= habit.category === 'other' ? 'selected' : '' %>>🌱 Прочее</option>
              </select>
            </div>


            <div class="mb-3">
              <label for="description" class="form-label">Описание</label>
              <textarea class="form-control" id="description" name="description"
                        rows="3" placeholder="Подробнее о вашей привычке..."><%= habit.description || '' %></textarea>
            </div>

            <div class="row">

              <div class="col-md-6 mb-3">
                <label for="frequency" class="form-label">Частота выполнения *</label>
                <select class="form-select" id="frequency" name="frequency" required>
                  <option value="daily" <%= habit.frequency === 'daily' ? 'selected' : '' %>>📅 Ежедневно</option>
                  <option value="weekly" <%= habit.frequency === 'weekly' ? 'selected' : '' %>>📆 Еженедельно</option>
                  <option value="monthly" <%= habit.frequency === 'monthly' ? 'selected' : '' %>>📊 Ежемесячно</option>
                </select>
              </div>


              <div class="col-md-6 mb-3">
                <label for="targetValue" class="form-label">Цель *</label>
                <div class="input-group">
                  <input type="number" class="form-control" id="targetValue"
                         name="targetValue" min="1" max="1000"
                         value="<%= habit.targetValue %>" required>
                  <select class="form-select" id="unit" name="unit" style="max-width: 120px;">
                    <option value="times" <%= habit.unit === 'times' ? 'selected' : '' %>>раз</option>
                    <option value="liters" <%= habit.unit === 'liters' ? 'selected' : '' %>>литров</option>
                    <option value="kwh" <%= habit.unit === 'kwh' ? 'selected' : '' %>>кВт·ч</option>
                    <option value="kg" <%= habit.unit === 'kg' ? 'selected' : '' %>>кг</option>
                    <option value="items" <%= habit.unit === 'items' ? 'selected' : '' %>>шт.</option>
                  </select>
                </div>
              </div>
            </div>


            <div class="mb-4">
              <label class="form-label">Цвет для визуализации</label>
              <div class="d-flex flex-wrap gap-2" id="colorPicker">
                <div class="color-option <%= habit.color === '#28a745' ? 'selected' : '' %>"
                     data-color="#28a745" style="background-color: #28a745;"></div>
                <div class="color-option <%= habit.color === '#17a2b8' ? 'selected' : '' %>"
                     data-color="#17a2b8" style="background-color: #17a2b8;"></div>
                <div class="color-option <%= habit.color === '#007bff' ? 'selected' : '' %>"
                     data-color="#007bff" style="background-color: #007bff;"></div>
                <div class="color-option <%= habit.color === '#6f42c1' ? 'selected' : '' %>"
                     data-color="#6f42c1" style="background-color: #6f42c1;"></div>
                <div class="color-option <%= habit.color === '#fd7e14' ? 'selected' : '' %>"
                     data-color="#fd7e14" style="background-color: #fd7e14;"></div>
                <div class="color-option <%= habit.color === '#e83e8c' ? 'selected' : '' %>"
                     data-color="#e83e8c" style="background-color: #e83e8c;"></div>
                <div class="color-option <%= habit.color === '#20c997' ? 'selected' : '' %>"
                     data-color="#20c997" style="background-color: #20c997;"></div>
                <div class="color-option <%= habit.color === '#ffc107' ? 'selected' : '' %>"
                     data-color="#ffc107" style="background-color: #ffc107;"></div>
              </div>
              <input type="hidden" id="color" name="color" value="<%= habit.color || '#28a745' %>">
            </div>


            <div class="mb-4">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch"
                       id="isActive" name="isActive" <%= habit.isActive ? 'checked' : '' %>>
                <label class="form-check-label" for="isActive">
                  Привычка активна
                </label>
              </div>
              <div class="form-text">
                Неактивные привычки не отображаются в списках и не учитываются в статистике
              </div>
            </div>


            <div class="card border-info mb-4">
              <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="bi bi-graph-up"></i> Текущая статистика</h6>
              </div>
              <div class="card-body">
                <div class="row text-center">
                  <div class="col-4">
                    <div class="text-muted small">Текущая серия</div>
                    <div class="fw-bold h5"><%= habit.currentStreak || 0 %></div>
                  </div>
                  <div class="col-4">
                    <div class="text-muted small">Лучшая серия</div>
                    <div class="fw-bold h5"><%= habit.bestStreak || 0 %></div>
                  </div>
                  <div class="col-4">
                    <div class="text-muted small">Всего выполнений</div>
                    <div class="fw-bold h5"><%= habit.totalCompletions || 0 %></div>
                  </div>
                </div>
                <div class="text-center mt-2">
                  <small class="text-muted">
                    Последнее выполнение:
                    <% if (habit.lastCompleted) { %>
                      <%= new Date(habit.lastCompleted).toLocaleDateString('ru-RU') %>
                    <% } else { %>
                      никогда
                    <% } %>
                  </small>
                </div>
              </div>
            </div>


            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
              <a href="/habits/<%= habit.id %>" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Назад к привычке
              </a>
              <div>
                <a href="/habits" class="btn btn-outline-secondary me-2">
                  <i class="bi bi-x-circle"></i> Отмена
                </a>
                <button type="submit" class="btn btn-warning px-4">
                  <i class="bi bi-check-lg"></i> Сохранить изменения
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>


      <div class="card border-danger mt-4">
        <div class="card-header bg-danger text-white">
          <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Опасная зона</h6>
        </div>
        <div class="card-body">
          <p class="card-text">
            Удаление привычки приведет к потере всей статистики и истории выполнения.
            Это действие нельзя отменить.
          </p>
          <form action="/habits/<%= habit.id %>" method="POST" class="d-inline">
            <input type="hidden" name="_method" value="DELETE">
            <button type="submit" class="btn btn-danger"
                    onclick="return confirm('Вы уверены, что хотите удалить привычку &quot;<%= habit.title %>&quot;?')">
              <i class="bi bi-trash"></i> Удалить привычку
            </button>
          </form>
          <button type="button" class="btn btn-outline-secondary ms-2"
                  onclick="resetHabit(<%= habit.id %>, '<%= habit.title %>')">
            <i class="bi bi-arrow-clockwise"></i> Сбросить статистику
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
