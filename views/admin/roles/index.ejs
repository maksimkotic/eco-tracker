<!-- views/admin/roles/index.ejs -->
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-shield text-info"></i> Управление ролями</h1>
            <p class="text-muted mb-0">Система ролевого доступа</p>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRoleModal">
            <i class="bi bi-plus-circle"></i> Создать роль
        </button>
    </div>

    <!-- Информация о ролях -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-primary border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-primary">
                        <% const userRole = roles.find(r => r.name === 'user'); %>
                        <%= userRole ? '1' : '0' %>
                    </div>
                    <small class="text-muted">Пользователь</small>
                    <div class="mt-2">
                        <span class="badge bg-primary">Базовые права</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-warning border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-warning">
                        <% const moderatorRole = roles.find(r => r.name === 'moderator'); %>
                        <%= moderatorRole ? '1' : '0' %>
                    </div>
                    <small class="text-muted">Модератор</small>
                    <div class="mt-2">
                        <span class="badge bg-warning">Расширенные права</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-danger border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-danger">
                        <% const adminRole = roles.find(r => r.name === 'admin'); %>
                        <%= adminRole ? '1' : '0' %>
                    </div>
                    <small class="text-muted">Администратор</small>
                    <div class="mt-2">
                        <span class="badge bg-danger">Полный доступ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Таблица ролей -->
    <div class="card shadow">
        <div class="card-body">
            <% if (roles.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название</th>
                                <th>Описание</th>
                                <th>Пользователей</th>
                                <th>Создана</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% roles.forEach(role => { 
                                // Подсчет пользователей с этой ролью
                                // В реальном приложении нужно получать из БД
                                const userCount = 0; // Замените на реальный подсчет
                            %>
                            <tr>
                                <td><%= role.id %></td>
                                <td>
                                    <span class="badge bg-<%= 
                                        role.name === 'admin' ? 'danger' : 
                                        role.name === 'moderator' ? 'warning' : 'primary'
                                    %>">
                                        <%= role.name %>
                                    </span>
                                </td>
                                <td><%= role.description || 'Нет описания' %></td>
                                <td>
                                    <span class="badge bg-secondary"><%= userCount %> пользователей</span>
                                </td>
                                <td>
                                    <%= new Date(role.createdAt).toLocaleDateString('ru-RU') %>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#editRoleModal<%= role.id %>">
                                            <i class="bi bi-pencil"></i> Редактировать
                                        </button>
                                        <% if (!['user', 'moderator', 'admin'].includes(role.name)) { %>
                                        <button class="btn btn-outline-danger" 
                                                onclick="deleteRole(<%= role.id %>, '<%= role.name %>')">
                                            <i class="bi bi-trash"></i> Удалить
                                        </button>
                                        <% } %>
                                    </div>

                                    <!-- Модальное окно редактирования роли -->
                                    <div class="modal fade" id="editRoleModal<%= role.id %>" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Редактирование роли: <%= role.name %></h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form action="/admin/roles/<%= role.id %>?_method=PUT" method="POST">
                                                    <div class="modal-body">
                                                        <div class="mb-3">
                                                            <label class="form-label">Название роли</label>
                                                            <input type="text" class="form-control" name="name" 
                                                                   value="<%= role.name %>" 
                                                                   <%= ['user', 'moderator', 'admin'].includes(role.name) ? 'readonly' : '' %> 
                                                                   required>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label">Описание</label>
                                                            <input type="text" class="form-control" name="description" 
                                                                   value="<%= role.description || '' %>">
                                                        </div>
                                                        
                                                        <h6 class="mt-3">Права доступа:</h6>
                                                        <% 
                                                        const allPermissions = [
                                                            { value: 'view_profile', label: 'Просмотр профиля' },
                                                            { value: 'edit_own_profile', label: 'Редактирование своего профиля' },
                                                            { value: 'create_habit', label: 'Создание привычек' },
                                                            { value: 'edit_own_habit', label: 'Редактирование своих привычек' },
                                                            { value: 'delete_own_habit', label: 'Удаление своих привычек' },
                                                            { value: 'view_achievements', label: 'Просмотр достижений' },
                                                            { value: 'view_all_habits', label: 'Просмотр всех привычек' },
                                                            { value: 'edit_any_habit', label: 'Редактирование любых привычек' },
                                                            { value: 'delete_any_habit', label: 'Удаление любых привычек' },
                                                            { value: 'create_achievement', label: 'Создание достижений' },
                                                            { value: 'edit_achievement', label: 'Редактирование достижений' },
                                                            { value: 'delete_achievement', label: 'Удаление достижений' },
                                                            { value: 'assign_achievement', label: 'Назначение достижений' },
                                                            { value: 'view_all_users', label: 'Просмотр всех пользователей' },
                                                            { value: 'edit_user_role', label: 'Изменение ролей пользователей' },
                                                            { value: 'delete_user', label: 'Удаление пользователей' },
                                                            { value: 'ban_user', label: 'Блокировка пользователей' },
                                                            { value: 'manage_roles', label: 'Управление ролями' },
                                                            { value: 'view_system_logs', label: 'Просмотр системных логов' },
                                                            { value: 'manage_settings', label: 'Управление настройками' }
                                                        ];
                                                        %>
                                                        
                                                        <div style="max-height: 300px; overflow-y: auto;" class="border p-3">
                                                            <% allPermissions.forEach(perm => { 
                                                                const hasPermission = role.permissions && role.permissions[perm.value];
                                                            %>
                                                            <div class="form-check mb-2">
                                                                <input class="form-check-input" type="checkbox" 
                                                                       name="permissions[]" value="<%= perm.value %>"
                                                                       id="perm<%= role.id %><%= perm.value %>"
                                                                       <%= hasPermission ? 'checked' : '' %>
                                                                       <%= ['user', 'moderator', 'admin'].includes(role.name) ? 'disabled' : '' %>>
                                                                <label class="form-check-label small" for="perm<%= role.id %><%= perm.value %>">
                                                                    <%= perm.label %>
                                                                </label>
                                                            </div>
                                                            <% }); %>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                                        <button type="submit" class="btn btn-primary">Сохранить</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="bi bi-shield" style="font-size: 4rem; color: #ccc;"></i>
                    <h4 class="mt-3">Роли не найдены</h4>
                    <p class="text-muted">Создайте первую роль</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Модальное окно создания роли -->
<div class="modal fade" id="createRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Создание новой роли</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/roles" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Название роли</label>
                        <input type="text" class="form-control" name="name" required 
                               placeholder="Например: content_manager">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание</label>
                        <input type="text" class="form-control" name="description" 
                               placeholder="Краткое описание роли">
                    </div>
                    
                    <h6 class="mt-3">Права доступа:</h6>
                    <div style="max-height: 300px; overflow-y: auto;" class="border p-3">
                        <% allPermissions = [
                            { value: 'view_profile', label: 'Просмотр профиля' },
                            { value: 'edit_own_profile', label: 'Редактирование своего профиля' },
                            { value: 'create_habit', label: 'Создание привычек' },
                            { value: 'edit_own_habit', label: 'Редактирование своих привычек' },
                            { value: 'delete_own_habit', label: 'Удаление своих привычек' },
                            { value: 'view_achievements', label: 'Просмотр достижений' },
                            { value: 'view_all_habits', label: 'Просмотр всех привычек' },
                            { value: 'edit_any_habit', label: 'Редактирование любых привычек' },
                            { value: 'delete_any_habit', label: 'Удаление любых привычек' },
                            { value: 'create_achievement', label: 'Создание достижений' },
                            { value: 'edit_achievement', label: 'Редактирование достижений' },
                            { value: 'delete_achievement', label: 'Удаление достижений' },
                            { value: 'assign_achievement', label: 'Назначение достижений' },
                            { value: 'view_all_users', label: 'Просмотр всех пользователей' },
                            { value: 'edit_user_role', label: 'Изменение ролей пользователей' },
                            { value: 'delete_user', label: 'Удаление пользователей' },
                            { value: 'ban_user', label: 'Блокировка пользователей' },
                            { value: 'manage_roles', label: 'Управление ролями' },
                            { value: 'view_system_logs', label: 'Просмотр системных логов' },
                            { value: 'manage_settings', label: 'Управление настройками' }
                        ]; %>
                        
                        <% allPermissions.forEach(perm => { %>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" 
                                   name="permissions[]" value="<%= perm.value %>"
                                   id="createPerm<%= perm.value %>">
                            <label class="form-check-label small" for="createPerm<%= perm.value %>">
                                <%= perm.label %>
                            </label>
                        </div>
                        <% }); %>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Создать роль</button>
                </div>
            </form>
        </div>
    </div>
</div>