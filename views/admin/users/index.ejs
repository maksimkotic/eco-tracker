<!-- views/admin/users/index.ejs -->
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-people text-primary"></i> Управление пользователями</h1>
            <p class="text-muted mb-0">Всего пользователей: <%= totalUsers %></p>
        </div>
        <div class="btn-group">
            <a href="/admin" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Назад
            </a>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
                <i class="bi bi-person-plus"></i> Добавить пользователя
            </button>
        </div>
    </div>

    <!-- Фильтры -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" name="search" placeholder="Поиск по имени или email..." 
                           value="<%= filters.search || '' %>">
                </div>
                <div class="col-md-3">
                    <select class="form-select" name="role">
                        <option value="all">Все роли</option>
                        <% roles.forEach(role => { %>
                        <option value="<%= role.name %>" <%= filters.role === role.name ? 'selected' : '' %>>
                            <%= role.name %>
                        </option>
                        <% }); %>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" name="status">
                        <option value="all">Все статусы</option>
                        <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Активные</option>
                        <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Неактивные</option>
                        <option value="banned" <%= filters.status === 'banned' ? 'selected' : '' %>>Заблокированные</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Применить
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Таблица пользователей -->
    <div class="card shadow">
        <div class="card-body">
            <% if (users.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Пользователь</th>
                                <th>Email</th>
                                <th>Роль</th>
                                <th>Эко-очки</th>
                                <th>Привычек</th>
                                <th>Статус</th>
                                <th>Регистрация</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(user => { %>
                            <tr class="<%= user.isBanned ? 'table-danger' : '' %>">
                                <td><%= user.id %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <% if (user.avatar) { %>
                                            <img src="/uploads/avatars/<%= user.avatar %>" 
                                                 width="40" height="40" class="rounded-circle me-3">
                                        <% } else { %>
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-3" 
                                                 style="width: 40px; height: 40px;">
                                                <i class="bi bi-person text-white"></i>
                                            </div>
                                        <% } %>
                                        <div>
                                            <div class="fw-bold"><%= user.username %></div>
                                            <small class="text-muted">Уровень: <%= user.level %></small>
                                        </div>
                                    </div>
                                </td>
                                <td><%= user.email %></td>
                                <td>
                                    <span class="badge bg-<%= 
                                        user.Role.name === 'admin' ? 'danger' : 
                                        user.Role.name === 'moderator' ? 'warning' : 'primary'
                                    %>">
                                        <%= user.Role.name === 'admin' ? 'Админ' : 
                                           user.Role.name === 'moderator' ? 'Модератор' : 
                                           user.Role.name === 'user' ? 'Пользователь' : 'Другая' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-success">
                                        <i class="bi bi-lightning-charge"></i> <%= user.ecoPoints %>
                                    </span>
                                </td>
                                <td>
                                    <% const habitCount = user.Habits ? user.Habits.length : 0; %>
                                    <span class="badge bg-info"><%= habitCount %></span>
                                </td>
                                <td>
                                    <% if (user.isBanned) { %>
                                        <span class="badge bg-danger">Заблокирован</span>
                                    <% } else { %>
                                        <span class="badge bg-success">Активен</span>
                                    <% } %>
                                </td>
                                <td>
                                    <%= new Date(user.createdAt).toLocaleDateString('ru-RU') %>
                                    <br>
                                    <small class="text-muted">
                                        <%= new Date(user.createdAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) %>
                                    </small>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/admin/users/<%= user.id %>" class="btn btn-outline-primary" 
                                           title="Просмотреть">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-warning" 
                                                title="Изменить роль"
                                                data-bs-toggle="modal" 
                                                data-bs-target="#changeRoleModal<%= user.id %>">
                                            <i class="bi bi-shield"></i>
                                        </button>
                                        <% if (user.id !== currentUser.id) { %>
                                            <% if (user.isBanned) { %>
                                                <form action="/admin/users/<%= user.id %>/ban" method="POST" 
                                                      class="d-inline" onsubmit="return confirm('Разблокировать пользователя?')">
                                                    <button type="submit" class="btn btn-outline-success" title="Разблокировать">
                                                        <i class="bi bi-unlock"></i>
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <form action="/admin/users/<%= user.id %>/ban" method="POST" 
                                                      class="d-inline" onsubmit="return confirm('Заблокировать пользователя?')">
                                                    <button type="submit" class="btn btn-outline-danger" title="Заблокировать">
                                                        <i class="bi bi-lock"></i>
                                                    </button>
                                                </form>
                                            <% } %>
                                            <button type="button" class="btn btn-outline-secondary" 
                                                    title="Сбросить пароль"
                                                    onclick="resetPassword(<%= user.id %>, '<%= user.username %>')">
                                                <i class="bi bi-key"></i>
                                            </button>
                                            <button type="button" class="btn btn-outline-danger" 
                                                    title="Удалить"
                                                    onclick="deleteUser(<%= user.id %>, '<%= user.username %>')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        <% } else { %>
                                            <span class="badge bg-info">Вы</span>
                                        <% } %>
                                    </div>

                                    <!-- Модальное окно смены роли -->
                                    <div class="modal fade" id="changeRoleModal<%= user.id %>" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Смена роли пользователя</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form action="/admin/users/<%= user.id %>/role" method="POST">
                                                    <div class="modal-body">
                                                        <p>Пользователь: <strong><%= user.username %></strong></p>
                                                        <p>Текущая роль: 
                                                            <span class="badge bg-<%= 
                                                                user.Role.name === 'admin' ? 'danger' : 
                                                                user.Role.name === 'moderator' ? 'warning' : 'primary'
                                                            %>">
                                                                <%= user.Role.name %>
                                                            </span>
                                                        </p>
                                                        <div class="mb-3">
                                                            <label class="form-label">Новая роль</label>
                                                            <select class="form-select" name="roleId" required>
                                                                <% roles.forEach(role => { %>
                                                                <option value="<%= role.id %>" 
                                                                        <%= user.roleId === role.id ? 'selected' : '' %>>
                                                                    <%= role.name %> - <%= role.description %>
                                                                </option>
                                                                <% }); %>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                                        <button type="submit" class="btn btn-primary">Сохранить</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Пагинация -->
                <% if (totalPages > 1) { %>
                <nav aria-label="Пагинация">
                    <ul class="pagination justify-content-center">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= filters.search || '' %>&role=<%= filters.role || '' %>&status=<%= filters.status || '' %>">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %>&search=<%= filters.search || '' %>&role=<%= filters.role || '' %>&status=<%= filters.status || '' %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                            <% } %>
                        <% } %>
                        
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= filters.search || '' %>&role=<%= filters.role || '' %>&status=<%= filters.status || '' %>">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
                <% } %>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="bi bi-people" style="font-size: 4rem; color: #ccc;"></i>
                    <h4 class="mt-3">Пользователи не найдены</h4>
                    <p class="text-muted">Попробуйте изменить параметры фильтрации</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Модальное окно создания пользователя -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Создание пользователя</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/users/create" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Имя пользователя</label>
                        <input type="text" class="form-control" name="username" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Пароль</label>
                        <input type="password" class="form-control" name="password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Роль</label>
                        <select class="form-select" name="roleId" required>
                            <% roles.forEach(role => { %>
                            <option value="<%= role.id %>"><%= role.name %> - <%= role.description %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Создать</button>
                </div>
            </form>
        </div>
    </div>
</div>