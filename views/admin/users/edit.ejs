<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>
                <i class="bi bi-pencil text-primary"></i> Редактирование пользователя
            </h1>
            <p class="text-muted mb-0">ID: <%= user.id %></p>
        </div>
        <div class="btn-group">
            <a href="/admin/users/<%= user.id %>" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Назад
            </a>
            <a href="/admin/users" class="btn btn-outline-primary">
                <i class="bi bi-people"></i> Все пользователи
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Редактирование данных пользователя</h5>
                </div>
                <div class="card-body">
                    <form action="/admin/users/<%= user.id %>?_method=PUT" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Имя пользователя</label>
                                <input type="text" class="form-control" name="username" 
                                       value="<%= user.username %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" 
                                       value="<%= user.email %>" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Роль</label>
                                <select class="form-select" name="roleId" required>
                                    <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>" 
                                            <%= user.roleId === role.id ? 'selected' : '' %>>
                                        <%= role.name %> - <%= role.description %>
                                    </option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Новый пароль</label>
                                <input type="password" class="form-control" name="password" 
                                       placeholder="Оставьте пустым для сохранения старого пароля">
                                <small class="text-muted">Минимум 6 символов</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Эко-очки</label>
                                <input type="number" class="form-control" name="ecoPoints" 
                                       value="<%= user.ecoPoints %>" min="0" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Уровень</label>
                                <input type="number" class="form-control" name="level" 
                                       value="<%= user.level %>" min="1" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="isBanned" 
                                       id="isBanned" <%= user.isBanned ? 'checked' : '' %>>
                                <label class="form-check-label" for="isBanned">
                                    Заблокировать аккаунт
                                </label>
                            </div>
                            <small class="text-muted">Заблокированные пользователи не могут войти в систему</small>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Внимание:</strong> Изменение этих параметров может повлиять на работу пользователя в системе.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/admin/users/<%= user.id %>" class="btn btn-secondary me-md-2">
                                Отмена
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Сохранить изменения
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow mt-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Текущая статистика</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center mb-3">
                            <div class="display-6 fw-bold text-primary">
                                <% const habitCount = user.Habits ? user.Habits.length : 0; %>
                                <%= habitCount %>
                            </div>
                            <small class="text-muted">Привычек</small>
                        </div>
                        <div class="col-md-4 text-center mb-3">
                            <div class="display-6 fw-bold text-success">
                                <% const achievementCount = user.UserAchievements ? user.UserAchievements.length : 0; %>
                                <%= achievementCount %>
                            </div>
                            <small class="text-muted">Достижений</small>
                        </div>
                        <div class="col-md-4 text-center mb-3">
                            <div class="display-6 fw-bold text-warning">
                                <%= user.currentStreak %>
                            </div>
                            <small class="text-muted">Дней подряд</small>
                        </div>
                    </div>
                    <div class="text-center">
                        <small class="text-muted">
                            Зарегистрирован: <%= new Date(user.createdAt).toLocaleDateString('ru-RU') %>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
