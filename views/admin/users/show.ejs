
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>
                <i class="bi bi-person-circle text-primary"></i> Пользователь: <%= user.username %>
            </h1>
            <p class="text-muted mb-0">ID: <%= user.id %> | Зарегистрирован: <%= new Date(user.createdAt).toLocaleDateString('ru-RU') %></p>
        </div>
        <div class="btn-group">
            <a href="/admin/users" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Все пользователи
            </a>
            <a href="/admin/users/<%= user.id %>/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil"></i> Редактировать
            </a>
        </div>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Основная информация</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <% if (user.avatar) { %>
                            <img src="/uploads/avatars/<%= user.avatar %>"
                                 class="rounded-circle" width="150" height="150">
                        <% } else { %>
                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto"
                                 style="width: 150px; height: 150px;">
                                <i class="bi bi-person text-white" style="font-size: 4rem;"></i>
                            </div>
                        <% } %>
                    </div>

                    <table class="table">
                        <tr>
                            <th>Имя пользователя:</th>
                            <td><%= user.username %></td>
                        </tr>
                        <tr>
                            <th>Email:</th>
                            <td><%= user.email %></td>
                        </tr>
                        <tr>
                            <th>Роль:</th>
                            <td>
                                <span class="badge bg-<%=
                                    user.Role.name === 'admin' ? 'danger' :
                                    user.Role.name === 'moderator' ? 'warning' : 'primary'
                                %>">
                                    <%= user.Role.name %>
                                </span>
                                <small class="text-muted"> - <%= user.Role.description %></small>
                            </td>
                        </tr>
                        <tr>
                            <th>Эко-очки:</th>
                            <td>
                                <span class="badge bg-success">
                                    <i class="bi bi-lightning-charge"></i> <%= user.ecoPoints %>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Уровень:</th>
                            <td><span class="badge bg-info">Уровень <%= user.level %></span></td>
                        </tr>
                        <tr>
                            <th>Текущая серия:</th>
                            <td><span class="badge bg-warning"><%= user.currentStreak %> дней</span></td>
                        </tr>
                        <tr>
                            <th>Последняя активность:</th>
                            <td><%= new Date(user.lastActive).toLocaleString('ru-RU') %></td>
                        </tr>
                        <tr>
                            <th>Статус:</th>
                            <td>
                                <% if (user.isBanned) { %>
                                    <span class="badge bg-danger">Заблокирован</span>
                                <% } else { %>
                                    <span class="badge bg-success">Активен</span>
                                <% } %>
                            </td>
                        </tr>
                    </table>

                    <div class="d-grid gap-2 mt-3">
                        <% if (user.id !== currentUser.id) { %>
                            <% if (user.isBanned) { %>
                                <form action="/admin/users/<%= user.id %>/ban" method="POST">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="bi bi-unlock"></i> Разблокировать
                                    </button>
                                </form>
                            <% } else { %>
                                <form action="/admin/users/<%= user.id %>/ban" method="POST"
                                      onsubmit="return confirm('Заблокировать пользователя?')">
                                    <button type="submit" class="btn btn-danger w-100">
                                        <i class="bi bi-lock"></i> Заблокировать
                                    </button>
                                </form>
                            <% } %>

                            <button type="button" class="btn btn-warning w-100"
                                    onclick="resetPassword(<%= user.id %>, '<%= user.username %>')">
                                <i class="bi bi-key"></i> Сбросить пароль
                            </button>

                            <button type="button" class="btn btn-danger w-100"
                                    onclick="deleteUser(<%= user.id %>, '<%= user.username %>')">
                                <i class="bi bi-trash"></i> Удалить аккаунт
                            </button>
                        <% } else { %>
                            <div class="alert alert-info text-center">
                                <i class="bi bi-info-circle"></i> Это ваш аккаунт
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>


            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Статистика</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 mb-3">
                            <div class="display-6 fw-bold text-primary"><%= stats.totalHabits || 0 %></div>
                            <small class="text-muted">Привычек</small>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="display-6 fw-bold text-success"><%= stats.totalAchievements || 0 %></div>
                            <small class="text-muted">Достижений</small>
                        </div>
                        <div class="col-6">
                            <div class="display-6 fw-bold text-warning"><%= stats.activeHabits || 0 %></div>
                            <small class="text-muted">Активных привычек</small>
                        </div>
                        <div class="col-6">
                            <div class="display-6 fw-bold text-danger"><%= stats.totalCheckins || 0 %></div>
                            <small class="text-muted">Отметок выполнения</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="col-md-8">

            <div class="card shadow mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-list-check text-primary"></i> Привычки пользователя</h5>
                    <span class="badge bg-primary"><%= stats.totalHabits || 0 %></span>
                </div>
                <div class="card-body">
                    <% if (user.Habits && user.Habits.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Название</th>
                                        <th>Категория</th>
                                        <th>Прогресс</th>
                                        <th>Статус</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% user.Habits.forEach(habit => { %>
                                    <tr>
                                        <td><%= habit.id %></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="color-indicator me-2"
                                                     style="width: 10px; height: 10px; background-color: <%= habit.color || '#28a745' %>;"></div>
                                                <a href="/habits/<%= habit.id %>" class="text-decoration-none">
                                                    <%= habit.title %>
                                                </a>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-<%=
                                                habit.category === 'water' ? 'primary' :
                                                habit.category === 'energy' ? 'warning' :
                                                habit.category === 'waste' ? 'danger' : 'success'
                                            %>">
                                                <%= habit.category === 'water' ? 'Вода' :
                                                   habit.category === 'energy' ? 'Энергия' :
                                                   habit.category === 'waste' ? 'Отходы' : 'Прочее' %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 10px;">
                                                <% const progress = Math.min((habit.currentStreak / habit.targetValue) * 100, 100); %>
                                                <div class="progress-bar bg-success" style="width: <%= progress %>%">
                                                    <%= Math.round(progress) %>%
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (habit.isActive) { %>
                                                <span class="badge bg-success">Активна</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Неактивна</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="/habits/<%= habit.id %>" class="btn btn-outline-primary">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="/moderator/habits/<%= habit.id %>/edit" class="btn btn-outline-warning">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="/moderator/habits?search=<%= user.username %>" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-list-check"></i> Все привычки пользователя
                            </a>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="bi bi-list-check" style="font-size: 3rem; color: #ccc;"></i>
                            <p class="mt-3">У пользователя нет привычек</p>
                        </div>
                    <% } %>
                </div>
            </div>


            <div class="card shadow">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-trophy text-warning"></i> Достижения пользователя</h5>
                    <span class="badge bg-warning"><%= stats.totalAchievements || 0 %></span>
                </div>
                <div class="card-body">
                    <% if (user.UserAchievements && user.UserAchievements.length > 0) { %>
                        <div class="row">
                            <% user.UserAchievements.forEach(ua => {
                                const achievement = ua.Achievement;
                            %>
                            <div class="col-md-6 mb-3">
                                <div class="card border-<%=
                                    achievement.rarity === 'legendary' ? 'danger' :
                                    achievement.rarity === 'epic' ? 'purple' :
                                    achievement.rarity === 'rare' ? 'primary' : 'success'
                                %>">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3">
                                                <i class="bi bi-<%= achievement.icon || 'trophy' %> display-6 text-<%=
                                                    achievement.rarity === 'legendary' ? 'danger' :
                                                    achievement.rarity === 'epic' ? 'purple' :
                                                    achievement.rarity === 'rare' ? 'primary' : 'success'
                                                %>"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-1"><%= achievement.title %></h6>
                                                <p class="mb-1 small text-muted"><%= achievement.description %></p>
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <small class="text-muted">
                                                        Получено: <%= new Date(ua.earnedAt).toLocaleDateString('ru-RU') %>
                                                    </small>
                                                    <span class="badge bg-success">
                                                        +<%= achievement.points %> очков
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                        <div class="text-center mt-3">
                            <a href="/achievements" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-trophy"></i> Все достижения
                            </a>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="bi bi-trophy" style="font-size: 3rem; color: #ccc;"></i>
                            <p class="mt-3">У пользователя нет достижений</p>
                            <button type="button" class="btn btn-warning btn-sm"
                                    onclick="assignAchievement(<%= user.id %>, '<%= user.username %>')">
                                <i class="bi bi-person-plus"></i> Назначить достижение
                            </button>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="assignAchievementModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Назначение достижения</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/moderator/achievements/assign" method="POST">
                <input type="hidden" name="userId" id="assignUserId">
                <div class="modal-body">
                    <p>Пользователь: <strong id="assignUserName"></strong></p>
                    <div class="mb-3">
                        <label class="form-label">Достижение</label>
                        <select class="form-select" name="achievementId" required>

                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Назначить</button>
                </div>
            </form>
        </div>
    </div>
</div>