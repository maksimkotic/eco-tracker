
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-trophy text-warning"></i> Управление достижениями</h1>
            <p class="text-muted mb-0">Создание и управление достижениями системы</p>
        </div>
        <div class="btn-group">
            <a href="/moderator" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Назад
            </a>
            <a href="/moderator/achievements/create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Создать достижение
            </a>
        </div>
    </div>


    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-warning border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-warning"><%= achievements.length %></div>
                    <small class="text-muted">Всего достижений</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-success">
                        <%= achievements.filter(a => a.rarity === 'common').length %>
                    </div>
                    <small class="text-muted">Обычных</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-primary border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-primary">
                        <%= achievements.filter(a => a.rarity === 'rare').length %>
                    </div>
                    <small class="text-muted">Редких</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger border-2">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-danger">
                        <%= achievements.filter(a => a.rarity === 'legendary').length %>
                    </div>
                    <small class="text-muted">Легендарных</small>
                </div>
            </div>
        </div>
    </div>


    <div class="card shadow">
        <div class="card-body">
            <% if (achievements.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название</th>
                                <th>Описание</th>
                                <th>Условие</th>
                                <th>Очки</th>
                                <th>Редкость</th>
                                <th>Получили</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% achievements.forEach(achievement => { %>
                            <tr class="<%=
                                achievement.rarity === 'legendary' ? 'table-danger' :
                                achievement.rarity === 'epic' ? 'table-purple' :
                                achievement.rarity === 'rare' ? 'table-primary' : ''
                            %>">
                                <td><%= achievement.id %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-<%= achievement.icon || 'trophy' %> text-<%=
                                            achievement.rarity === 'legendary' ? 'danger' :
                                            achievement.rarity === 'epic' ? 'purple' :
                                            achievement.rarity === 'rare' ? 'primary' : 'warning'
                                        %> me-2"></i>
                                        <div>
                                            <div><%= achievement.title %></div>
                                            <% if (achievement.isHidden) { %>
                                            <small class="badge bg-dark">Скрытое</small>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        <%= achievement.description || 'Нет описания' %>
                                    </small>
                                </td>
                                <td>
                                    <small>
                                        <%
                                        let conditionText = '';
                                        switch(achievement.conditionType) {
                                            case 'streak':
                                                conditionText = `${achievement.conditionValue} дней подряд`;
                                                break;
                                            case 'total_habits':
                                                conditionText = `${achievement.conditionValue} привычек`;
                                                break;
                                            case 'eco_points':
                                                conditionText = `${achievement.conditionValue} эко-очков`;
                                                break;
                                            case 'days_active':
                                                conditionText = `${achievement.conditionValue} активных дней`;
                                                break;
                                            case 'specific_habit':
                                                conditionText = `Специальная привычка`;
                                                break;
                                            case 'category_master':
                                                conditionText = `Мастер категории`;
                                                break;
                                            default:
                                                conditionText = achievement.conditionType;
                                        }
                                        %>
                                        <%= conditionText %>
                                    </small>
                                </td>
                                <td>
                                    <span class="badge bg-success">+<%= achievement.points %></span>
                                </td>
                                <td>
                                    <span class="badge bg-<%=
                                        achievement.rarity === 'legendary' ? 'danger' :
                                        achievement.rarity === 'epic' ? 'purple' :
                                        achievement.rarity === 'rare' ? 'primary' : 'warning'
                                    %>">
                                        <%=
                                            achievement.rarity === 'legendary' ? 'Легендарное' :
                                            achievement.rarity === 'epic' ? 'Эпическое' :
                                            achievement.rarity === 'rare' ? 'Редкое' : 'Обычное'
                                        %>
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1" style="height: 10px;">
                                            <div class="progress-bar bg-success" style="width: <%= achievement.percentage || 0 %>%"></div>
                                        </div>
                                        <small class="ms-2">
                                            <%= achievement.earnedCount || 0 %> (<%= achievement.percentage || 0 %>%)
                                        </small>
                                    </div>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editAchievementModal<%= achievement.id %>">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger"
                                                onclick="deleteAchievement(<%= achievement.id %>, '<%= achievement.title %>')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        <a href="/moderator/achievements/assign?achievementId=<%= achievement.id %>"
                                           class="btn btn-outline-success" title="Назначить">
                                            <i class="bi bi-person-plus"></i>
                                        </a>
                                    </div>


                                    <div class="modal fade" id="editAchievementModal<%= achievement.id %>" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Редактирование: <%= achievement.title %></h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form action="/moderator/achievements/<%= achievement.id %>?_method=PUT" method="POST">
                                                    <div class="modal-body">
                                                        <div class="mb-3">
                                                            <label class="form-label">Название</label>
                                                            <input type="text" class="form-control" name="title"
                                                                   value="<%= achievement.title %>" required>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label">Описание</label>
                                                            <textarea class="form-control" name="description"
                                                                      rows="2"><%= achievement.description || '' %></textarea>
                                                        </div>
                                                        <div class="row">
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label">Очки</label>
                                                                <input type="number" class="form-control" name="points"
                                                                       value="<%= achievement.points %>" min="1" required>
                                                            </div>
                                                            <div class="col-md-6 mb-3">
                                                                <label class="form-label">Иконка</label>
                                                                <select class="form-select" name="icon">
                                                                    <option value="trophy" <%= achievement.icon === 'trophy' ? 'selected' : '' %>>🏆 Трофей</option>
                                                                    <option value="star" <%= achievement.icon === 'star' ? 'selected' : '' %>>⭐ Звезда</option>
                                                                    <option value="award" <%= achievement.icon === 'award' ? 'selected' : '' %>>🎖️ Награда</option>
                                                                    <option value="medal" <%= achievement.icon === 'medal' ? 'selected' : '' %>>🥇 Медаль</option>
                                                                    <option value="crown" <%= achievement.icon === 'crown' ? 'selected' : '' %>>👑 Корона</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="form-check mb-3">
                                                            <input class="form-check-input" type="checkbox" name="isHidden"
                                                                   id="isHidden<%= achievement.id %>" <%= achievement.isHidden ? 'checked' : '' %>>
                                                            <label class="form-check-label" for="isHidden<%= achievement.id %>">
                                                                Скрытое достижение
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                                        <button type="submit" class="btn btn-primary">Сохранить</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="bi bi-trophy" style="font-size: 4rem; color: #ccc;"></i>
                    <h4 class="mt-3">Достижения не найдены</h4>
                    <p class="text-muted">Создайте первое достижение</p>
                    <a href="/moderator/achievements/create" class="btn btn-primary mt-2">
                        <i class="bi bi-plus-circle"></i> Создать достижение
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</div>
