{
  "name": "eco-tracker",
  "version": "1.0.0",
  "description": "Система отслеживания экологических привычек",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "init-db": "node database/init.js",
    "reset-db": "node database/init.js --force",
    "check:syntax": "node --check app.js && node --check controllers/*.js && node --check routes/*.js && node --check middlewares/*.js && node --check models/*.js && node --check database/*.js && node --check utils/*.js",
    "check": "npm run check:syntax"
  },
  "keywords": [
    "eco",
    "tracker",
    "habits",
    "express",
    "sequelize"
  ],
  "author": "Eco Tracker",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-flash": "^0.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^6.10.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "sequelize": "^6.35.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  }
}
